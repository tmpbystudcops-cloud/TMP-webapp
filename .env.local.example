# ---- Supabase (create a project at https://supabase.com) ----
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Project Settings -> API -> service_role secret. SERVER ONLY. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- Telegram notifications (optional; order placement still works without these) ----
# Create a bot with @BotFather, then get your chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Optional: bearer token for a scheduled /api/cleanup-old-orders cron job ----
# (Not needed for local dev — the admin dashboard triggers cleanup with the admin password.)
CRON_SECRET=
